<%- include('./partials/header.ejs', { bodyClass: 'edit' }) %>

<h1>Edit Tank</h1>

<form action="/tanks/<%= tank.id %>/edit" method="POST" class="edit-form">
    <div class="form-group">
        <label>Name</label>
        <input type="text" name="name" value="<%= tank.name %>" required />
    </div>
    <div class="form-group">
        <label>Type</label>
        <input type="text" name="type" value="<%= tank.type %>" required />
    </div>
    <div class="form-group">
        <label>Caliber</label>
        <input type="text" name="caliber" value="<%= tank.caliber %>" required />
    </div>
    <div class="form-group">
        <label>Faction</label>
        <input type="text" name="faction" value="<%= tank.faction %>" required />
    </div>
    <div class="form-group">
        <label></label>
        <input type="submit" value="Update">
    </div>
</form>

<ul class="action-list">
    <li><a href="/tanks">back to list</a></li>
    <li>
        <form method="post" action="/tanks/<%= tank.id %>/delete" onsubmit="return confirm('Are you sure you want to delete this item?');">
            <input type="submit" value="Delete">
        </form>
    </li>
</ul>

<%- include('./partials/footer.ejs') %>
